import streamlit as st
import json
import os
from datetime import date

st.set_page_config(page_title="BH Student Wellness App")

page = st.sidebar.radio("Navigation", [
    "Home",
    "Daily Check-In",
    "8 Wellness Pillars",
    "Stressor Topics",
    "Yoga and Meditation",
    "Resource Hub",
])

# ── HOME ──────────────────────────────────────────────────────────────────────
if page == "Home":
    st.title("BH Student Wellness App")
    st.write("Your daily guide to managing stress in college.")

# ── DAILY CHECK-IN ────────────────────────────────────────────────────────────
elif page == "Daily Check-In":
    st.title("Daily Check-In")

    mood = st.slider("Rate your mood (1 = struggling, 5 = great)", 1, 5, 3)

    focus = st.selectbox("What is your biggest wellness focus today?", [
        "Physical wellness",
        "Emotional wellness",
        "Social wellness",
        "Intellectual wellness",
        "Occupational wellness",
        "Spiritual wellness",
        "Environmental wellness",
        "Financial wellness",
    ])

    goal = st.text_input("My goal today is...")

    if st.button("Save Check-In"):
        if not goal:
            st.warning("Please enter a goal before saving.")
        else:
            entry = {"date": str(date.today()), "mood": mood, "focus": focus, "goal": goal}
            filepath = "data/checkins.json"
            os.makedirs("data", exist_ok=True)
            all_entries = []
            if os.path.exists(filepath):
                with open(filepath) as f:
                    all_entries = json.load(f)
            all_entries.append(entry)
            with open(filepath, "w") as f:
                json.dump(all_entries, f, indent=4)

            pillar_map = {k + " wellness": k.capitalize() for k in
                          ["physical","emotional","social","intellectual",
                           "occupational","spiritual","environmental","financial"]}
            st.session_state["wellness_pillar"] = pillar_map.get(focus.lower(), focus)
            st.success("Check-in saved! Head to 8 Wellness Pillars for personalized tips.")
            st.balloons()

